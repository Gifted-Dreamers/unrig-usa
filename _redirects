# Cloudflare Pages redirects — preserve links from the old site structure.
# Format: <source>  <destination>  <status>
#
# IMPORTANT: CF Pages auto-strips .html from URLs (308 → /about). Do NOT add
# rules like /about → /about.html — that creates a redirect loop with CF's
# default behavior. Both /about and /about.html serve the same page natively.

# Legacy pages from the old site that no longer exist as standalone pages.
# Both with and without .html for safety.
/framework        /safeguards             301
/framework.html   /safeguards             301
/team             /about#team             301
/team.html        /about#team             301
/news             /                       301
/news.html        /                       301
/recognize        /the-problem            301
/recognize.html   /the-problem            301
/research         /safeguards             301
/research.html    /safeguards             301
